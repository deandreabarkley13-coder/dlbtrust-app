# ─── OpenACH API Credentials ─────────────────────────────────────────────────
# OpenACH instance hosted on Fly.io at dlbtrust-app.fly.dev

OPENACH_BASE_URL=https://dlbtrust-app.fly.dev/openach/api
OPENACH_API_TOKEN=REPLACE_WITH_TOKEN_FROM_SETUP_SCRIPT
OPENACH_API_KEY=REPLACE_WITH_KEY_FROM_SETUP_SCRIPT

# The "Trust Dist" payment type ID — get by running:
#   node server/integrations/openach/test-api.js
# after setting token and key above
OPENACH_PAYMENT_TYPE_ID=REPLACE_AFTER_RUNNING_TEST
