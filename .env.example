# Supabase Configuration
# Copy this file to .env and fill in your values

# Your Supabase project URL
VITE_SUPABASE_URL=https://ihegrfvgdwkivpsrmdzs.supabase.co

# Your Supabase anon/public key (safe to expose in browser)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── PostgreSQL (Bond Master Record) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/dlbtrust

# ─── Apache Fineract (Core Banking) ──────────────────────────────────────────
FINERACT_URL=http://localhost:8443/fineract-provider/api/v1
FINERACT_USER=mifos
FINERACT_PASS=password
FINERACT_TENANT=default

# ─── Open Bank Project ───────────────────────────────────────────────────────
OBP_URL=https://your-obp-instance/obp/v4.0.0
OBP_CONSUMER_KEY=
OBP_TOKEN=

# ─── Bank SFTP ───────────────────────────────────────────────────────────────
SFTP_HOST=
SFTP_USER=
SFTP_KEY_PATH=
SFTP_OUTBOUND=/outbound/ach/
SFTP_INBOUND=/inbound/returns/

# ─── Document Services ───────────────────────────────────────────────────────
DMS_URL=http://localhost:8090
DOCGEN_URL=http://localhost:8091
