# Supabase Configuration (for auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Server Configuration
PORT=3002
NODE_ENV=development
JWT_SECRET=change_this_to_a_secure_random_string
DATABASE_PATH=./data/dlbtrust.db

# Admin secret token for /api/admin routes
ADMIN_SECRET_TOKEN=change-me-in-production

# Payment system mode: 'sandbox' (default) or 'production'
PAYMENT_MODE=sandbox

# PostgreSQL bond database name
BOND_DB_NAME=fineract_tenants

# AS2 Pipeline Configuration (ACH file delivery to bank)
AS2_PARTNER_URL=https://your-bank-as2-endpoint.com/as2
AS2_PARTNER_AS2_ID=BANK-AS2-ID
AS2_LOCAL_AS2_ID=DLBTRUST-AS2
AS2_SIGNING_CERT=/path/to/signing-cert.pem
AS2_SIGNING_KEY=/path/to/signing-key.pem
AS2_PARTNER_CERT=/path/to/partner-cert.pem
AS2_ENCRYPTION_ALG=aes256-cbc
AS2_SIGNING_ALG=sha256
AS2_REQUEST_MDN=true
AS2_MESSAGE_ID_DOMAIN=dlbtrust-app.fly.dev
AS2_PRODUCTION_APPROVED=false

# ACH files storage directory (default: data/ach-files)
# ACH_FILES_DIR=/var/data/ach-files

# Payment Hub orchestration: disabled, shadow, local_ach, or phee
PAYMENT_HUB_MODE=disabled
PAYMENT_HUB_LIVE=false
PAYMENT_APPROVAL_THRESHOLD=2
PAYMENT_ALLOW_SELF_APPROVAL=false
PAYMENT_HOLD_HOURS=72

# Generate with: openssl rand -hex 32
PAYMENT_DATA_ENCRYPTION_KEY=replace-with-64-hex-characters
PAYMENT_HUB_SERVICE_TOKEN=replace-with-a-random-service-token
PAYMENT_HUB_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
PAYMENT_HUB_WEBHOOK_MAX_AGE_SECONDS=300

# Required only when PAYMENT_HUB_MODE=phee
PAYMENT_HUB_BASE_URL=https://payment-hub.example.com
PAYMENT_HUB_AUTH_TOKEN=replace-with-payment-hub-api-token
PAYMENT_HUB_CALLBACK_URL=https://dlbtrust-app.fly.dev/api/payment-hub/webhooks/status
PAYMENT_HUB_ACH_CONNECTOR_URL=https://dlbtrust-app.fly.dev/api/payment-hub/connectors/us-ach/execute
PAYMENT_HUB_TIMEOUT_MS=15000
PAYMENT_HUB_MAX_RETRIES=3

# Bank-approved NACHA originator values for local_ach or the U.S. ACH connector
ACH_ODFI_ROUTING=000000001
ACH_ODFI_NAME=YOUR ODFI
ACH_IMMEDIATE_ORIGIN=replace-me
ACH_ORIGINATOR_NAME=YOUR TRUST COMPANY
ACH_COMPANY_NAME=YOUR TRUST COMPANY
ACH_COMPANY_ID=replace-me
ACH_PARTNER_ID=your-configured-bank-partner

# Required for legacy wire records; live transmission remains disabled without a certified connector
WIRE_SENDER_NAME=YOUR TRUST COMPANY
WIRE_SENDER_ROUTING=replace-with-approved-routing
WIRE_SENDER_ACCOUNT=replace-with-approved-account
WIRE_SENDER_ADDRESS=replace-with-originator-address
