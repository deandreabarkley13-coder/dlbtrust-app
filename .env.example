# ─── DLB Trust App — Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
DB_PATH=./data/dlbtrust.db

# ─── Supabase (front-end) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://ihegrfvgdwkivpsrmdzs.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── OpenACH Integration ─────────────────────────────────────────────────────
# See server/.env.openach for setup instructions.
OPENACH_BASE_URL=https://ach.dlbtrust.cloud/openach/api
OPENACH_HOST_HEADER=ach.dlbtrust.cloud
OPENACH_API_TOKEN=your_openach_api_token
OPENACH_API_KEY=your_openach_api_key
OPENACH_PAYMENT_TYPE_ID=your_payment_type_id

# ─── Deployment / Plesk (CI only — set these as GitHub Actions secrets) ───────
# SERVER=74.208.191.205
# SSH_USER=your_ssh_user
# SERVER_PASSWORD=your_server_password
# PLESK_ADMIN_PASSWORD=your_plesk_admin_password
# DOMAIN=dlbtrust.cloud
