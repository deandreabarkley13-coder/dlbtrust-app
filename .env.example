# Supabase Configuration
# Copy this file to .env and fill in your values

# Your Supabase project URL
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase anon/public key (safe to expose in browser)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# OpenACH Integration
OPENACH_BASE_URL=http://localhost/openach/api
OPENACH_API_TOKEN=your_openach_token_here
OPENACH_API_KEY=your_openach_key_here
OPENACH_USER_ID=your_user_id_here
OPENACH_ORIGINATOR_ID=your_originator_id_here

# Server
PORT=3001
NODE_ENV=production

# CORS (comma-separated allowed origins for standalone server)
CORS_ALLOWED_ORIGINS=https://dlbtrust.cloud
