# DEANDREA LAVAR BARKLEY TRUST — Treasury Management System
# Copy this to .env and fill in your values

# PostgreSQL connection (required)
DATABASE_URL=postgres://user:password@host:5432/dlbtrust
DB_SSL=true

# Server
PORT=3001
NODE_ENV=development

# OpenACH Integration (optional — for external ACH transfers)
OPENACH_BASE_URL=https://ach.dlbtrust.cloud/api
OPENACH_API_TOKEN=
OPENACH_API_KEY=
OPENACH_USER_ID=
OPENACH_ORIGINATOR_ID=
